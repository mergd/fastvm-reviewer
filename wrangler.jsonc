{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "fastvm-pr-reviewer-api",
  "main": "src/worker.ts",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat_v2"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "triggers": {
    "crons": ["0 * * * *"]
  }
}
